        #     "variable_X": "M1"
        # }
    ]

    # 3. Lancer la boucle de traitement
    for roi in rois_a_traiter:
        try:
            lateralize_and_rename(
                input_nifti_path=roi["chemin"],
                roi_variable=roi["variable_X"],
                output_dir=destination_dir
            )
        except Exception as e:
            print(f"❌ Erreur lors du traitement de {roi['variable_X']} : {e}\n")