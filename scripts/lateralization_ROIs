import numpy as np
import nibabel as nib
from pathlib import Path

def lateralize_and_rename(input_nifti_path, roi_variable, output_dir):
    """
    Coupe un masque NIfTI au centre de l'axe X (Gauches/Droite)
    et le sauvegarde sous la nomenclature : roi_variable_y_sphere.nii.gz
    où y est 'L' ou 'R'.
    """
    input_path = Path(input_nifti_path)
    output_dir = Path(output_dir)
    output_dir.mkdir(parents=True, exist_ok=True)

    if not input_path.exists():
        raise FileNotFoundError(f"Le fichier source n'existe pas : {input_path}")

    # 1. Charger l'image NIfTI
    img = nib.load(str(input_path))
    data = img.get_fdata()
    affine = img.affine
    header = img.header

    # 2. Trouver le centre de la matrice sur l'axe X (première dimension)
    x_dim_size = data.shape[0]
    mid_x = x_dim_size // 2

    print(f"Traitement du masque pour la ROI '{roi_variable}'...")
    print(f"  -> Fichier source : {input_path.name}")
    print(f"  -> Taille de la matrice : {data.shape} | Index de coupe : {mid_x}")

    # 3. Séparation Gauche (L) et Droite (R)
    # Dans l'espace MNI/RAS standard, les premiers index de X sont à Gauche (L)
    # et les index supérieurs sont à Droite (R).
    left_data = np.zeros_like(data)
    right_data = np.zeros_like(data)

    left_data[:mid_x, :, :] = data[:mid_x, :, :]
    right_data[mid_x:, :, :] = data[mid_x:, :, :]

    # 4. Application stricte de la nomenclature : X_y_sphere.nii.gz
    left_filename = f"{roi_variable}_L_sphere.nii.gz"
    right_filename = f"{roi_variable}_R_sphere.nii.gz"

    left_path = output_dir / left_filename
    right_path = output_dir / right_filename

    # Sauvegarde des fichiers NIfTI
    nib.save(nib.Nifti1Image(left_data, affine, header), str(left_path))
    nib.save(nib.Nifti1Image(right_data, affine, header), str(right_path))

    print(f"  ✓ Sauvegardé Gauche : {left_filename}")
    print(f"  ✓ Sauvegardé Droite : {right_filename}\n")


# ============================================================================
# EXÉCUTION COMPLÈTE SUR VOS NOUVEAUX MASQUES
