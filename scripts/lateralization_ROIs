if __name__ == "__main__":
    # 1. Définir le dossier de sortie (votre dossier centralisé /mask)
    destination_dir = "/Users/alex/university/Neuroscience_Master/short-term internship/derivatives_MNIcohort3/mask"

    # 2. Définir vos fichiers sources et associer la variable X correspondante
    # Vous pouvez ajouter ou modifier les chemins ici très facilement
    rois_a_traiter = [
        {
            "chemin": "/Users/alex/university/Neuroscience_Master/short-term internship/new mask/neurosynth_auditory_mask.nii.gz",
            "variable_X": "A1"
        },
        # {
        #     "chemin": "/Users/alex/university/Neuroscience_Master/short-term internship/new mask/votre_masque_visuel.nii.gz",
        #     "variable_X": "V1"
        # },
        # {
